---
---

<section class="hero" id="hero">
  <div class="container hero-inner">
    <h1 class="glitch" data-text="Coherence between architecture and code.">Coherence between architecture and code.</h1>
    <p class="hero-subtitle">
      <span class="typed" id="typed-subtitle"></span><span class="cursor"></span>
    </p>
    <p class="hero-byline">A <a href="https://viewyonder.com" target="_blank" rel="noopener noreferrer">Viewyonder</a> product</p>
    <p class="hero-desc">
      A system of hooks, agents, skills, and specification documents that encode your project's
      architectural constraints into the Claude Code development loop.
    </p>
    <div class="hero-actions">
      <a href="/getting-started" class="btn btn-primary">Get Started</a>
      <a
        href="https://github.com/viewyonder/coherence"
        class="btn btn-secondary btn-github"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="github-icon" viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        View on GitHub
      </a>
    </div>
    <div class="hero-social-proof">
      <a href="https://github.com/viewyonder/coherence" target="_blank" rel="noopener noreferrer">
        <img
          src="https://img.shields.io/github/stars/viewyonder/coherence?style=flat&logo=github&color=00e5ff&labelColor=0d1117"
          alt="GitHub stars"
          width="90"
          height="20"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 4rem;
    position: relative;
  }

  .hero-inner {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--cyan);
    margin-bottom: 2rem;
    min-height: 1.8em;
  }

  .hero-byline {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
  }

  .hero-byline a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .hero-byline a:hover {
    color: var(--cyan);
  }

  .hero-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    max-width: 60ch;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-github {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .github-icon {
    flex-shrink: 0;
  }

  .hero-social-proof {
    margin-top: 1.5rem;
  }

  .hero-social-proof a {
    display: inline-block;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .hero-social-proof a:hover {
    opacity: 1;
  }

</style>
