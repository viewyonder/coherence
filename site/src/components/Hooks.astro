---
---

<section id="hooks">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Layer 1</p>
      <h2 class="section-title">One Hook, Zero Friction</h2>
      <p class="section-desc">
        A single informational hook tracks your edits and nudges you to run
        <code>/coherence</code> when drift is likely. No blocking, no warnings —
        just a timely reminder.
      </p>

      <div class="hook-card card">
        <div class="hook-header">
          <code class="hook-name">spec-drift-nudge</code>
          <span class="badge badge-info">informational</span>
        </div>
        <p class="hook-desc">
          Watches for accumulated edits and elapsed time since your last drift check.
          When either threshold is reached, it nudges you to run <code>/coherence</code>.
        </p>
        <div class="hook-thresholds">
          <div class="threshold">
            <span class="threshold-value">50</span>
            <span class="threshold-label">edits</span>
          </div>
          <div class="threshold-or">or</div>
          <div class="threshold">
            <span class="threshold-value">7</span>
            <span class="threshold-label">days</span>
          </div>
          <div class="threshold-then">then nudge</div>
        </div>
        <p class="hook-throttle">30-minute throttle between nudges</p>
      </div>

      <div class="hook-demo">
        <p class="demo-label">Example: Nudge after threshold</p>
        <div class="hook-output">
          53 edits since last drift check (threshold: 50).<br />
          Consider running <code>/coherence</code> to check for spec drift.
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hook-card {
    max-width: 550px;
    margin-bottom: 2rem;
    border-top: 3px solid var(--amber);
  }

  .hook-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .hook-name {
    font-size: 1rem;
    background: none;
    padding: 0;
    color: var(--text-primary);
  }

  .hook-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .hook-thresholds {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .threshold {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--bg-surface);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1.25rem;
    min-width: 80px;
  }

  .threshold-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--amber);
  }

  .threshold-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .threshold-or, .threshold-then {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .threshold-then {
    color: var(--cyan);
  }

  .hook-throttle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0;
  }

  .hook-demo {
    max-width: 550px;
  }

  .demo-label {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .hook-output {
    background: var(--bg-mid);
    border: 1px solid var(--bg-surface);
    border-left: 3px solid var(--amber);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .hook-output code {
    color: var(--cyan);
    background: rgba(0, 255, 240, 0.08);
  }
</style>
