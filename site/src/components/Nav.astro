---
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-bracket">[</span>Coherence<span class="logo-bracket">]</span>
    </a>
    <div class="nav-links">
      <a href="/getting-started">Get Started</a>
      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger">Docs <span class="dropdown-arrow">&#9662;</span></button>
        <div class="nav-dropdown-menu">
          <a href="/plugins">Plugins</a>
          <a href="/#architecture">Architecture</a>
          <a href="/#hooks">Hooks</a>
          <a href="/#examples">Examples</a>
        </div>
      </div>
      <div class="nav-dropdown">
        <button class="nav-dropdown-trigger">More <span class="dropdown-arrow">&#9662;</span></button>
        <div class="nav-dropdown-menu">
          <a href="/blog">Blog</a>
          <a href="/faq">FAQ</a>
          <a href="/changelog">Changelog</a>
        </div>
      </div>
      <a
        href="https://github.com/viewyonder/coherence"
        class="nav-github"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
    <button class="nav-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 255, 240, 0.1);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .logo-bracket {
    color: var(--cyan);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--cyan);
    opacity: 1;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-dropdown-trigger:hover {
    color: var(--cyan);
  }

  .dropdown-arrow {
    font-size: 0.65rem;
    transition: transform 0.2s;
  }

  .nav-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-surface);
    border: 1px solid rgba(0, 255, 240, 0.15);
    border-radius: var(--radius);
    padding: 0.5rem 0;
    min-width: 10rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .nav-dropdown.open .nav-dropdown-menu {
    display: flex;
    flex-direction: column;
  }

  .nav-dropdown-menu a {
    padding: 0.5rem 1rem;
    white-space: nowrap;
  }

  .nav-dropdown-menu a:hover {
    background: var(--bg-elevated);
  }

  .nav-github {
    background: var(--bg-surface);
    padding: 0.4em 1em;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(0, 255, 240, 0.2);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
    transition: transform 0.2s;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      flex-direction: column;
      background: rgba(10, 10, 15, 0.95);
      padding: 1rem var(--gap);
      border-bottom: 1px solid var(--bg-surface);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-dropdown-menu {
      position: static;
      transform: none;
      background: none;
      border: none;
      box-shadow: none;
      padding: 0 0 0 1rem;
      min-width: 0;
    }

    .nav-dropdown.open .nav-dropdown-menu {
      display: flex;
    }

    .nav-dropdown-menu a:hover {
      background: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    links?.classList.toggle('open');
  });

  // Dropdown toggles
  document.querySelectorAll('.nav-dropdown-trigger').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const dropdown = btn.closest('.nav-dropdown');
      // Close other dropdowns
      document.querySelectorAll('.nav-dropdown.open').forEach(d => {
        if (d !== dropdown) d.classList.remove('open');
      });
      dropdown?.classList.toggle('open');
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-dropdown.open').forEach(d => d.classList.remove('open'));
  });

  // Close everything on link click
  links?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links?.classList.remove('open');
      document.querySelectorAll('.nav-dropdown.open').forEach(d => d.classList.remove('open'));
    });
  });
</script>
