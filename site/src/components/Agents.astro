---
const agents = [
  {
    name: 'Drift Detector',
    type: 'Review',
    desc: 'Compares SPEC documents and SPEC-PRINCIPLES against codebase. Reports CURRENT / DRIFTED / UNDOCUMENTED status.',
    access: 'Read-only',
  },
  {
    name: 'Spec Reviewer',
    type: 'Review',
    desc: 'Reviews plans and implementation proposals against SPEC constraints. Reports ALIGNED / AT_RISK / VIOLATED.',
    access: 'Read-only',
  },
  {
    name: 'Code Reviewer',
    type: 'Review',
    desc: 'Quality, maintainability, and best practices. Focuses on significant issues, not nitpicks.',
    access: 'Read-only',
  },
  {
    name: 'Consistency Reviewer',
    type: 'Review',
    desc: 'Terminology, voice, structure, and cross-reference checks for writing, docs, and brand content.',
    access: 'Read-only',
  },
  {
    name: 'Security Auditor',
    type: 'Review',
    desc: 'OWASP Top 10 focused. Severity-classified with exploit scenarios and fix recommendations.',
    access: 'Read-only',
  },
];

const modes = [
  {
    mode: 'Scaffold',
    trigger: 'No SPEC files found',
    desc: 'Generates CLAUDE.md, SPEC docs, hooks, and agents',
  },
  {
    mode: 'Setup',
    trigger: 'SPECs exist but CLAUDE.md lacks references',
    desc: 'Wires existing SPECs into your CLAUDE.md',
  },
  {
    mode: 'Drift',
    trigger: 'Default when SPECs exist',
    desc: 'Compares every SPEC claim against codebase reality',
  },
  {
    mode: 'Plan Review',
    trigger: '/coherence plan',
    desc: 'Reviews plan docs via spec-reviewer agent',
  },
  {
    mode: 'Fix',
    trigger: '/coherence fix',
    desc: 'Drift detection + auto-applies fixes',
  },
];
---

<section id="agents">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Layers 2 & 4</p>
      <h2 class="section-title">Agents & Modes</h2>
      <p class="section-desc">
        Agents are specialized personas with defined tools and output formats.
        <code>/coherence</code> auto-detects the right mode and invokes the right agents.
      </p>

      <div class="agents-grid grid-2">
        {agents.map((agent) => (
          <div class="card agent-card">
            <div class="agent-header">
              <h3>{agent.name}</h3>
              <span class="badge badge-info">{agent.access}</span>
            </div>
            <p class="agent-desc">{agent.desc}</p>
          </div>
        ))}
      </div>

      <h3 class="modes-title">Auto-Detected Modes</h3>
      <p class="modes-desc">
        One command — <code>/coherence</code> — examines your project and picks the right mode automatically.
      </p>
      <div class="modes-list">
        {modes.map((m) => (
          <div class="mode-item">
            <code class="mode-name">{m.mode}</code>
            <span class="mode-trigger">{m.trigger}</span>
            <span class="mode-desc">{m.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .agent-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .agent-header h3 {
    font-size: 1.1rem;
  }

  .agent-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .modes-title {
    margin-top: 3rem;
    margin-bottom: 0.5rem;
    color: var(--cyan);
  }

  .modes-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .modes-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 700px;
  }

  .mode-item {
    display: grid;
    grid-template-columns: 110px 1fr 1fr;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--bg-mid);
    border-radius: var(--radius-sm);
    border: 1px solid var(--bg-surface);
  }

  .mode-name {
    font-size: 0.9rem;
    white-space: nowrap;
    color: var(--green);
    background: none;
    padding: 0;
    font-weight: 600;
  }

  .mode-trigger {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .mode-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .mode-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
