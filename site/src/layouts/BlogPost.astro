---
import Base from './Base.astro';
import BottomCTA from '../components/BottomCTA.astro';

interface Props {
  title: string;
  subtitle?: string;
  date: Date;
  author: string;
  legacyVersion?: boolean;
}

const { title, subtitle, date, author, legacyVersion } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Coherence by Viewyonder`} description={subtitle}>
  <article class="container blog-article">
    <header class="blog-article-header">
      <a href="/blog" class="back-link">
        &larr; Back to blog
      </a>
      <h1>{title}</h1>
      {subtitle && <p class="blog-article-subtitle">{subtitle}</p>}
      <div class="blog-article-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="meta-sep">&middot;</span>
        <span>{author}</span>
      </div>
    </header>
    {legacyVersion && (
      <div class="version-banner">
        <strong>Earlier version.</strong> This post describes a previous version of Coherence.
        Since v1.13.0, Coherence uses a single auto-detecting <code>/coherence</code> skill
        and one informational hook. <a href="/changelog">See the changelog</a>.
      </div>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>
  <BottomCTA />
</Base>

<style>
  .blog-article {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .blog-article-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: inline-block;
    margin-bottom: 2rem;
  }

  .blog-article-header h1 {
    margin-bottom: 0.75rem;
  }

  .blog-article-subtitle {
    color: var(--text-secondary);
    font-size: 1.15rem;
    max-width: 60ch;
    margin: 0 auto;
  }

  .blog-article-meta {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .meta-sep {
    margin: 0 0.5rem;
  }

  .version-banner {
    background: rgba(255, 170, 0, 0.08);
    border: 1px solid rgba(255, 170, 0, 0.25);
    border-left: 3px solid var(--amber, #ffa600);
    border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
  }

  .version-banner strong {
    color: var(--amber, #ffa600);
  }

  .version-banner code {
    font-size: 0.85rem;
  }

  .version-banner a {
    color: var(--cyan);
  }

  @media (max-width: 480px) {
    .blog-article {
      padding-top: 5rem;
    }
  }
</style>
