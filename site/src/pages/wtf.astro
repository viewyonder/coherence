    content: '\2717';
    color: rgba(255, 60, 60, 0.8);
  }

  .contrast-with {
    background: rgba(0, 255, 136, 0.06);
    border: 1px solid rgba(0, 255, 136, 0.2);
  }

  .contrast-with li {
    color: var(--text-secondary);
  }

