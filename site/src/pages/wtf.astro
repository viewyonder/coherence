    color: var(--amber);
    border: 1px solid rgba(255, 170, 0, 0.3);
  }

  .lifecycle-detail {
    flex: 1;
    min-width: 0;
  }

  .lifecycle-detail strong {
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .lifecycle-detail p {
    font-size: 0.9rem;
    margin-bottom: 0;
    margin-top: 0.25rem;
  }

  /* Archetype grid */
  .archetype-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--gap);
    margin: 1.5rem 0;
  }

  .archetype-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
  }

  .archetype-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .archetype-hooks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .archetype-hooks .badge {
    font-size: 0.65rem;
  }

  /* Contrast cards (without/with) */
  .contrast-card {
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
  }

  .contrast-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contrast-card li {
    font-size: 0.9rem;
    padding: 0.35rem 0;
    padding-left: 1.5rem;
    position: relative;
  }

  .contrast-card li::before {
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
  }

  .contrast-without {
    background: rgba(255, 60, 60, 0.06);
    border: 1px solid rgba(255, 60, 60, 0.2);
  }

  .contrast-without li {
    color: var(--text-secondary);
  }

