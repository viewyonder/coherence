  }

  /* Responsive */
  @media (max-width: 600px) {
    .comparison-row {
      grid-template-columns: 1fr;
    }

    .comparison-row div:not(:last-child) {
      padding-bottom: 0.25rem;
    }

    .comparison-header {
      display: none;
    }

    .comparison-approach::before {
      content: attr(data-label);
    }

    .layer-row {
      grid-template-columns: 1fr;
    }

    .layer-header {
      display: none;
    }

    .lifecycle-step {
      flex-direction: column;
      gap: 0.5rem;
    }

    .archetype-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
